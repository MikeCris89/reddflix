{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2023"],
		"types": ["vitest/globals"],

		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,

		"esModuleInterop": true,
		"resolveJsonModule": true,
		"isolatedModules": true,

		"noEmit": true,
		"skipLibCheck": true
	},
	"include": ["src", "../shared"]
}
